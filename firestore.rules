rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // ============================================
    // Users Collection
    // ============================================
    match /users/{userId} {
      // Users can read their own document
      // Students can read their Mentor's document
      // Faculty can read their allocated students' documents
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "student" && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.mentorId == userId) ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "faculty" && resource.data.mentorEmail == request.auth.token.email) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
      
      // Admins have full access
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ============================================
    // Events Collection
    // ============================================
    match /events/{eventId} {
      // Anyone logged in can view events
      allow read: if request.auth != null;
      // Only Admins can modify events
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ============================================
    // Registrations Collection
    // ============================================
    match /registrations/{registrationId} {
      // Admin sees all. Faculty sees registrations where they are the mentor. Student sees their own.
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        resource.data.mentorId == request.auth.uid || 
        resource.data.studentId == request.auth.uid
      );
      // Students can insert pending registrations
      allow create: if request.auth != null && 
                    request.resource.data.studentId == request.auth.uid && 
                    request.resource.data.status == "pending";
      // Faculty/Admins can modify
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        resource.data.mentorId == request.auth.uid
      );
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ============================================
    // Requests Collection (Permission Letters)
    // ============================================
    match /requests/{requestId} {
      // Admin sees all. Faculty sees their mentees'. Student sees their own.
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        resource.data.mentorId == request.auth.uid ||
        resource.data.studentId == request.auth.uid
      );
      // Students request permissions natively
      allow create: if request.auth != null && 
                    request.resource.data.studentId == request.auth.uid &&
                    request.resource.data.status == "pending";
      // Faculty accepts/rejects
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        resource.data.mentorId == request.auth.uid
      );
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ============================================
    // Attendance Collection
    // ============================================
    match /attendance/{docId} {
      // Admin, Faculty, and Student access scopes
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "faculty") ||
        resource.data.studentId == request.auth.uid
      );
      // Faculty commits attendance statuses
      allow write: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "faculty"
      );
    }

    // ============================================
    // Notifications Collection
    // ============================================
    match /notifications/{notificationId} {
      // Student reads their own alerts
      allow read: if request.auth != null && (
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
         resource.data.studentId == request.auth.uid
      );
      // Faculty generates alerts during Accept/Reject phase
      allow write: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "faculty"
      );
    }

  }
}
